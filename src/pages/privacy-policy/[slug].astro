---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { privacyPolicies, type AppPrivacyPolicy } from '../../data/privacy-policies';

export function getStaticPaths() {
  return privacyPolicies.map((policy) => ({
    params: {
      slug: policy.slug
    },
    props: {
      policy
    }
  }));
}

type Props = {
  policy: AppPrivacyPolicy;
};

const { policy } = Astro.props;

const activeFeatures = [
  policy.features.localStorage && 'Local Device Storage',
  policy.features.ads && 'Advertising',
  policy.features.analytics && 'Analytics',
  policy.features.crashReporting && 'Crash Reporting',
  policy.features.inAppPurchases && 'In-App Purchases',
  policy.features.subscriptions && 'Subscriptions',
  policy.features.notifications && 'Notifications',
  policy.features.location && 'Location Access',
  policy.features.camera && 'Camera Access',
  policy.features.mediaFiles && 'Media / File Access',
  policy.features.accountSystem && 'Account System',
  policy.features.cloudSync && 'Cloud Sync'
].filter(Boolean);
---

<BaseLayout
  title={`${policy.appName} — Privacy Policy`}
  description={policy.shortDescription}
>
  <section class="py-14 sm:py-20">
    <div class="container-page">
      <div class="mx-auto max-w-5xl">
        <a
          href="/privacy-center/"
          class="inline-flex items-center rounded-full border border-white/15 bg-white/[0.06] px-4 py-2 text-sm font-bold text-slate-100 transition hover:bg-white/[0.12]"
        >
          ← Privacy Policy Center
        </a>

        <header class="mt-8 overflow-hidden rounded-[2rem] border border-white/15 bg-white/[0.08] shadow-soft backdrop-blur-xl">
          <div class="border-b border-white/10 px-6 py-8 sm:px-10">
            <p class="text-sm font-bold uppercase tracking-[0.32em] text-cyan-200">
              Official Privacy Policy
            </p>

            <h1 class="mt-5 text-4xl font-black tracking-tight text-white sm:text-5xl">
              {policy.appName}
            </h1>

            <p class="mt-5 max-w-3xl text-base leading-8 text-slate-300">
              {policy.shortDescription}
            </p>
          </div>

          <div class="grid divide-y divide-white/10 sm:grid-cols-2 sm:divide-x sm:divide-y-0 lg:grid-cols-4">
            <div class="px-6 py-5 sm:px-8">
              <p class="text-xs font-bold uppercase tracking-[0.22em] text-slate-400">Developer</p>
              <p class="mt-2 text-sm font-bold text-white">{policy.developerName}</p>
            </div>

            <div class="px-6 py-5 sm:px-8">
              <p class="text-xs font-bold uppercase tracking-[0.22em] text-slate-400">Effective Date</p>
              <p class="mt-2 text-sm font-bold text-white">{policy.effectiveDate}</p>
            </div>

            <div class="px-6 py-5 sm:px-8">
              <p class="text-xs font-bold uppercase tracking-[0.22em] text-slate-400">Last Updated</p>
              <p class="mt-2 text-sm font-bold text-white">{policy.lastUpdated}</p>
            </div>

            <div class="px-6 py-5 sm:px-8">
              <p class="text-xs font-bold uppercase tracking-[0.22em] text-slate-400">Country</p>
              <p class="mt-2 text-sm font-bold text-white">{policy.country}</p>
            </div>
          </div>
        </header>

        <div class="mt-8 grid gap-8 lg:grid-cols-[260px_1fr] lg:items-start">
          <aside class="rounded-[1.5rem] border border-white/15 bg-white/[0.06] p-5 backdrop-blur-xl lg:sticky lg:top-24">
            <p class="text-xs font-bold uppercase tracking-[0.24em] text-cyan-200">
              Document Summary
            </p>

            <div class="mt-5 space-y-4 text-sm">
              <div>
                <p class="text-slate-400">Website</p>
                <a href={policy.companyWebsite} class="mt-1 block break-all font-bold text-white hover:text-cyan-100">
                  {policy.companyWebsite}
                </a>
              </div>

              <div>
                <p class="text-slate-400">Contact Email</p>
                <a href={`mailto:${policy.contactEmail}`} class="mt-1 block break-all font-bold text-white hover:text-cyan-100">
                  {policy.contactEmail}
                </a>
              </div>
            </div>

            <div class="mt-6 border-t border-white/10 pt-5">
              <p class="text-xs font-bold uppercase tracking-[0.24em] text-cyan-200">
                Covered Features
              </p>

              <div class="mt-4 flex flex-wrap gap-2">
                {activeFeatures.map((feature) => (
                  <span class="rounded-full border border-cyan-200/10 bg-cyan-300/10 px-3 py-1 text-xs font-semibold text-cyan-50">
                    {feature}
                  </span>
                ))}
              </div>
            </div>
          </aside>

          <article class="rounded-[2rem] border border-white/15 bg-white p-6 text-slate-800 shadow-soft sm:p-10">
            <div class="border-b border-slate-200 pb-6">
              <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">
                Privacy Policy Document
              </p>

              <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-950">
                {policy.appName}
              </h2>

              <p class="mt-4 text-base leading-8 text-slate-600">
                This document explains how user information is handled when using the application.
              </p>
            </div>

            <div class="privacy-document mt-8">
              <section>
                <h2>1. Introduction</h2>
                <p>
                  This Privacy Policy explains how {policy.appName} (“the App”, “we”, “our”, or “us”)
                  collects, uses, stores, and protects information when users access or use the App.
                </p>
                <p>
                  By using the App, users agree to the practices described in this Privacy Policy.
                  If users do not agree with this Privacy Policy, they should stop using the App.
                </p>
              </section>

              <section>
                <h2>2. Information We May Collect</h2>
                <p>{policy.dataCollectionSummary}</p>
                <p>
                  Depending on the features available in the App, we may process information provided
                  by users, app usage information, device information, diagnostic data, purchase-related
                  information, advertising identifiers, or data stored locally on the user’s device.
                </p>
              </section>

              <section>
                <h2>3. How We Use Information</h2>
                <ul>
                  <li>To provide, operate, and maintain the App;</li>
                  <li>To save user preferences and app settings;</li>
                  <li>To improve app quality, reliability, and user experience;</li>
                  <li>To provide customer support;</li>
                  <li>To monitor app performance and fix technical issues;</li>
                  {policy.features.ads && <li>To display advertisements and measure ad performance;</li>}
                  {policy.features.inAppPurchases && <li>To process purchases and manage premium access;</li>}
                  {policy.features.subscriptions && <li>To manage subscriptions and related entitlements;</li>}
                  {policy.features.notifications && <li>To send reminders or notifications when enabled by the user;</li>}
                  <li>To comply with applicable legal, security, or platform requirements.</li>
                </ul>
              </section>

              <section>
                <h2>4. Third-Party Services</h2>
                <p>
                  The App may use third-party services that process certain information according to
                  their own privacy policies and terms.
                </p>
                <ul>
                  <li>Google Play Services</li>
                  {policy.features.ads && <li>Google AdMob or Google Mobile Ads SDK</li>}
                  {policy.features.analytics && <li>Google Analytics for Firebase or similar analytics services</li>}
                  {policy.features.crashReporting && <li>Firebase Crashlytics or similar crash reporting services</li>}
                  {policy.features.notifications && <li>Firebase Cloud Messaging or notification-related services</li>}
                  {policy.features.inAppPurchases && <li>Google Play Billing</li>}
                  {policy.features.inAppPurchases && <li>RevenueCat or similar purchase management services, if used</li>}
                </ul>
              </section>

              <section>
                <h2>5. Advertising</h2>
                <p>
                  The App may display advertisements through third-party advertising services such as
                  Google AdMob. Advertising services may use device identifiers, advertising IDs, cookies,
                  or similar technologies to serve ads, measure ad performance, prevent fraud, and improve
                  ad relevance.
                </p>
              </section>

              <section>
                <h2>6. In-App Purchases and Subscriptions</h2>
                <p>
                  The App may offer in-app purchases, subscriptions, or premium features. Payments are
                  processed through official platform providers such as Google Play Billing. We do not
                  directly collect or store full payment card details.
                </p>
              </section>

              <section>
                <h2>7. App Permissions</h2>
                <p>
                  The App may request device permissions only when required for relevant features.
                  Users can manage or revoke permissions through their device settings.
                </p>
              </section>

              <section>
                <h2>8. Data Sharing</h2>
                <p>
                  We do not sell users’ personal information. Limited information may be shared with
                  third-party service providers used to operate, analyze, monetize, secure, or improve the App.
                </p>
              </section>

              <section>
                <h2>9. Data Retention</h2>
                <p>
                  Information is retained only for as long as necessary to provide the App, support app
                  functionality, comply with legal obligations, resolve disputes, and improve our services.
                </p>
              </section>

              <section>
                <h2>10. Data Security</h2>
                <p>
                  We use reasonable technical and organizational measures to protect user information from
                  unauthorized access, loss, misuse, alteration, or disclosure. However, no electronic storage
                  or transmission method is completely secure.
                </p>
              </section>

              <section>
                <h2>11. Children’s Privacy</h2>
                <p>
                  The App is not intended for children under the age of 13 unless specifically stated otherwise
                  in the App’s store listing and compliance settings. We do not knowingly collect personal
                  information from children under 13.
                </p>
              </section>

              <section>
                <h2>12. User Rights and Choices</h2>
                <p>
                  Depending on applicable laws and the App’s available features, users may request access,
                  correction, or deletion of personal information, withdraw consent where applicable, disable
                  permissions through device settings, opt out of personalized advertising where supported,
                  or delete local app data by clearing app storage or uninstalling the App.
                </p>
              </section>

              <section>
                <h2>13. International Data Processing</h2>
                <p>
                  Some third-party service providers may process or store information on servers located outside
                  the user’s country of residence. By using the App, users understand that information may be
                  processed in countries with different data protection laws.
                </p>
              </section>

              <section>
                <h2>14. Changes to This Privacy Policy</h2>
                <p>
                  We may update this Privacy Policy from time to time to reflect changes in the App, legal
                  requirements, platform policies, or business practices.
                </p>
              </section>

              <section>
                <h2>15. Contact Us</h2>
                <p>
                  If users have questions, concerns, or requests regarding this Privacy Policy, they may contact us:
                </p>

                <div class="mt-5 rounded-2xl border border-slate-200 bg-slate-50 p-5">
                  <p><strong>{policy.developerName}</strong></p>
                  <p>Email: <a href={`mailto:${policy.contactEmail}`}>{policy.contactEmail}</a></p>
                  <p>Website: <a href={policy.companyWebsite}>{policy.companyWebsite}</a></p>
                  <p>Country: {policy.country}</p>
                </div>
              </section>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <style>
    .privacy-document {
      color: #334155;
      font-size: 1rem;
      line-height: 1.85;
    }

    .privacy-document section + section {
      margin-top: 2.25rem;
      padding-top: 2.25rem;
      border-top: 1px solid #e2e8f0;
    }

    .privacy-document h2 {
      color: #0f172a;
      font-size: 1.35rem;
      line-height: 1.35;
      font-weight: 900;
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
    }

    .privacy-document p {
      margin-top: 0.85rem;
      color: #475569;
    }

    .privacy-document ul {
      margin-top: 1rem;
      padding-left: 1.4rem;
      color: #475569;
      list-style: disc;
    }

    .privacy-document li + li {
      margin-top: 0.45rem;
    }

    .privacy-document a {
      color: #0f172a;
      font-weight: 700;
      text-decoration: underline;
      text-underline-offset: 3px;
    }
  </style>
</BaseLayout>
